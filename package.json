{
  "name": "career-assistant",
  "version": "1.0.0",
  "description": "RAG-powered career assistant for job-fit scoring, skill gap analysis, and resume optimization",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rag",
    "langchain",
    "career",
    "resume",
    "openai",
    "pinecone",
    "vector-search"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "@langchain/pinecone": "^0.1.0",
    "@pinecone-database/pinecone": "^4.0.0",
    "dotenv": "^16.4.0",
    "langchain": "^0.3.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
